# Скопируйте в `.env` и заполните. Файл `.env` в git не коммитится.
# Подробнее: README.md (раздел про переменные окружения).

# --- PostgreSQL (check_schema.py и backend) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_SCHEMA=public

# --- Аутентификация API (docs/automation.md §3.2) ---
# Секрет между BotHelp и backend для путей /api/v1/bot/*
BOT_CONSTRUCTOR_SECRET=замените_на_длинную_случайную_строку
# Отдельный секрет для /api/v1/internal/* (cron, sync), не совпадает с BOT_CONSTRUCTOR_SECRET
INTERNAL_API_SECRET=другая_длинная_случайная_строка

# Публичный базовый URL backend (https://..., без завершающего слеша)
APP_PUBLIC_BASE_URL=https://example.com

# --- Google OAuth 2.0 (Google Cloud Console → Credentials → OAuth 2.0 Client ID) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Обычно: {APP_PUBLIC_BASE_URL}/api/v1/google/oauth/callback — зарегистрируйте тот же URI в консоли Google
GOOGLE_OAUTH_REDIRECT_URI=https://example.com/api/v1/google/oauth/callback

# --- Шифрование refresh/access в БД (docs/data_model.md, calendar_connections) ---
# Сгенерируйте криптостойкий ключ; формат (base64/hex/длина) задаётся кодом backend
OAUTH_CREDENTIALS_ENCRYPTION_KEY=

# --- Опционально ---
# GOOGLE_GEOCODING_API_KEY=
